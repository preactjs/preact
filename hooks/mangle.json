{
  "help": {
    "what is this file?": "It controls protected/private property mangling so that minified builds have consistent property names.",
    "why are there duplicate minified properties?": "Most properties are only used on one type of objects, so they can have the same name since they will never collide. Doing this reduces size."
  },
  "minify": {
    "mangle": {
      "properties": {
        "regex": "^_[^_]",
        "reserved": [
          "__SECRET_INTERNALS_DO_NOT_USE_OR_YOU_WILL_BE_FIRED",
          "__REACT_DEVTOOLS_GLOBAL_HOOK__",
          "__PREACT_DEVTOOLS__",
          "_renderers",
          "__source",
          "__self"
        ]
      }
    }
  },
  "props": {
    "cname": 28,
    "props": {
      "$_args": "a",
      "$_bits": "b",
      "$_catchError": "c",
      "$_children": "d",
      "$_cleanup": "e",
      "$_commit": "f",
      "$_component": "g",
      "$_context": "h",
      "$_defaultValue": "i",
      "$_diff": "j",
      "$_factory": "k",
      "$_hasScuFromHooks": "l",
      "$_hook": "m",
      "$_id": "n",
      "$_list": "o",
      "$_mask": "p",
      "$_nextValue": "q",
      "$_parent": "r",
      "$_parentDom": "s",
      "$_pendingArgs": "t",
      "$_pendingEffects": "u",
      "$_reducer": "v",
      "$_render": "w",
      "$_renderCallbacks": "x",
      "$_root": "y",
      "$_skipEffects": "z",
      "$_value": "A",
      "$_vnode": "B"
    }
  }
}
