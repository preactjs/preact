{
  "help": {
    "what is this file?": "It controls protected/private property mangling so that minified builds have consistent property names.",
    "why are there duplicate minified properties?": "Most properties are only used on one type of objects, so they can have the same name since they will never collide. Doing this reduces size."
  },
  "minify": {
    "mangle": {
      "properties": {
        "regex": "^_[^_]",
        "reserved": [
          "__SECRET_INTERNALS_DO_NOT_USE_OR_YOU_WILL_BE_FIRED",
          "__REACT_DEVTOOLS_GLOBAL_HOOK__",
          "__PREACT_DEVTOOLS__",
          "_renderers",
          "__source",
          "__self"
        ]
      }
    }
  },
  "props": {
    "cname": 29,
    "props": {
      "$_bits": "a",
      "$_catchError": "b",
      "$_childDidSuspend": "c",
      "$_children": "d",
      "$_cleanup": "e",
      "$_component": "f",
      "$_container": "g",
      "$_detachOnNextRender": "h",
      "$_dom": "i",
      "$_flags": "j",
      "$_getSnapshot": "k",
      "$_globalContext": "l",
      "$_id": "m",
      "$_instance": "n",
      "$_list": "o",
      "$_mask": "p",
      "$_onResolve": "q",
      "$_original": "r",
      "$_originalParentDom": "s",
      "$_parent": "t",
      "$_parentDom": "u",
      "$_pendingSuspensionCount": "v",
      "$_render": "w",
      "$_suspended": "x",
      "$_suspenders": "y",
      "$_temp": "z",
      "$_unmounted": "A",
      "$_value": "B",
      "$_vnode": "C"
    }
  }
}
